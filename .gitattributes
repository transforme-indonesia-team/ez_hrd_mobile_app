# Auto detect text files and normalize to LF
* text=auto eol=lf

# Dart files
*.dart text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.md text eol=lf

# Config files
*.properties text eol=lf
*.gradle text eol=lf
*.pro text eol=lf
*.cfg text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Batch files (keep CRLF for Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (don't touch)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.jar binary
*.keystore binary
